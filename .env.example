# Core
PORT=8080
AUTH_SECRET=replace_with_strong_secret
DATABASE_URL=postgresql://username:password@localhost:5432/msme_db

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional admin bootstrap
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me
ADMIN_FULLNAME=System Admin
ADMIN_MOBILE=9999999999

# Map services (used for DB bootstrap if key is missing)
MSME_BASE_REFERENCE_URL=
MSME_ADMIN_BOUNDARIES_URL=
MSME_ENVIRONMENT_URL=
MSME_INVESTMENT_URL=
MSME_SOCIAL_URL=
MSME_TRANSPORT_URL=
MSME_UTILITIES_URL=
MSME_CADASTRAL_URL=
MSME_CONSTITUENCY_URL=

# SMS provider
SMS_API_URL=
SMS_API_KEY=
SMS_SENDER_ID=
SMS_TEMP_DLT_ID=
SMS_ROUTE=Domestic
SMS_TRANS=1
SMS_UNICODE=0
SMS_FLASH=false
SMS_TINY=false
SMS_GROUP_IDS=

# Google auth
GOOGLE_CLIENT_ID=
GOOGLE_TOKENINFO_URL=https://oauth2.googleapis.com/tokeninfo
GOOGLE_DEFAULT_MOBILE=9999999999

# OTP user bootstrap defaults
OTP_DEFAULT_FULLNAME=Citizen
